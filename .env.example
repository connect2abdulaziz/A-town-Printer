# Copy this file to .env.local and fill in your values.
# Do not commit .env.local or real .env files.

# Node (optional; Next.js sets NODE_ENV automatically)
# NODE_ENV=development

# MongoDB
MONGODB_URI=

# AWS S3 (file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional: defaults to eu-west-1 if not set
AWS_REGION=
# Optional: alternative to AWS_REGION
# AWS_DEFAULT_REGION=
# Optional: public URL for S3 bucket (e.g. https://bucket.s3.region.amazonaws.com or CloudFront URL)
AWS_S3_PUBLIC_URL=

# Resend (email)
RESEND_API_KEY=
# Optional: sender address (defaults to Resend onboarding address if not set)
EMAIL_FROM=

# Admin / notifications (optional; used for notifying admins)
ADMIN_EMAIL=
# Alternative env name for admin email
# NOTIFY_EMAIL=
